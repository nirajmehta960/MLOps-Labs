# Copy to .env in this folder (or merge with existing .env from ./setup.sh).
# docker-compose.yaml loads .env automatically; restart containers after changes.

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Inbox for pipeline_success_email and quality_gate_failed_email.
PIPELINE_ALERT_EMAIL=your-email@example.com

# --- SMTP (required for EmailOperator to actually send) ---
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
# SMTP_USER = the Gmail address you send FROM. SMTP_PASSWORD = the 16-character app password.
SMTP_USER=your.sender@gmail.com
SMTP_PASSWORD=your-16-char-app-password
